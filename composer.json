{
    "name": "univapay/php-sdk",
    "description": "PHP SDK for Univapay Payments",
    "type": "library",
    "keywords": ["univapay", "payment", "credit card" , "japan"],
    "homepage": "https://github.com/univapay/univapay-php-sdk",
    "license": "MIT",
    "scripts": {
        "lint": "phpcs --standard=PSR12 src tests",
        "lint:fix": "phpcbf --standard=PSR12 src tests",
        "test": "phpunit tests"
    },
    "require": {
        "php": ">=7.2",
        "rmccue/requests": "^2.0",
        "moneyphp/money": "^3.3 || ^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5 || ^9.6 || ^10.5 || ^11.5 || ^12.5 || ^13.5",
        "squizlabs/php_codesniffer": "^3.7" 
    },
    "autoload": {
        "psr-0": {
            "Univapay": "src/"
        }
    },
    "autoload-dev": {
        "classmap": [
            "tests/Univapay"
        ]
    }
}
